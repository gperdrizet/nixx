[Unit]
Description=nixx API server
After=network.target postgresql.service ollama.service
Requires=postgresql.service
Wants=ollama.service

[Service]
Type=simple
User=siderealyear
WorkingDirectory=/home/siderealyear/nixx
ExecStart=/home/siderealyear/nixx/venv/bin/nixx serve
Restart=on-failure
RestartSec=5s
EnvironmentFile=/home/siderealyear/nixx/.env

# Security hardening
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=nixx.target
