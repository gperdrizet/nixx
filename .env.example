# Nixx environment configuration
# Copy to .env and fill in values. Never commit .env to version control.

# ── Server ────────────────────────────────────────────────────────────────────
NIXX_HOST=127.0.0.1
NIXX_PORT=8000
NIXX_RELOAD=false

# ── LLM ──────────────────────────────────────────────────────────────────────
# llama.cpp server with OpenAI-compatible API
NIXX_LLM_BASE_URL=http://localhost:8080
NIXX_LLM_MODEL=gpt-oss-20b
NIXX_LLM_TEMPERATURE=0.7
NIXX_LLM_CONTEXT_LENGTH=8192
# NIXX_LLM_API_KEY=

# ── Memory ────────────────────────────────────────────────────────────────────
NIXX_EMBEDDING_BASE_URL=http://localhost:8082
NIXX_EMBEDDING_MODEL=mxbai-embed-large

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL + pgvector via Docker (run: docker compose up -d)
NIXX_DATABASE_URL=postgresql://nixx:changeme@localhost:5432/nixx

# Password for the nixx PostgreSQL role.
# Used by docker-compose and scripts/init-db.sh.
# NIXX_POSTGRES_PASSWORD=changeme

