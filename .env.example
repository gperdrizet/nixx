# Nixx environment configuration
# Copy to .env and fill in values. Never commit .env to version control.

# ── Server ────────────────────────────────────────────────────────────────────
NIXX_HOST=127.0.0.1
NIXX_PORT=8000
NIXX_RELOAD=false

# ── LLM ──────────────────────────────────────────────────────────────────────
NIXX_LLM_PROVIDER=ollama
NIXX_LLM_BASE_URL=http://localhost:11434
NIXX_LLM_MODEL=qwen2.5-coder:7b
NIXX_LLM_TEMPERATURE=0.7

# ── Memory (ChromaDB) ─────────────────────────────────────────────────────────
NIXX_MEMORY_PROVIDER=chroma
NIXX_MEMORY_PATH=./data/memory
NIXX_EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Database ──────────────────────────────────────────────────────────────────
# Tier 1 — zero-config (default, no setup required)
NIXX_DATABASE_URL=sqlite:///./data/nixx.db

# Tier 2 — local PostgreSQL via docker-compose (run: docker compose up -d)
# NIXX_DATABASE_URL=postgresql://nixx:changeme@localhost:5433/nixx

# Tier 3 — bring your own PostgreSQL (local or remote)
# NIXX_DATABASE_URL=postgresql://nixx:changeme@localhost:5432/nixx
# NIXX_DATABASE_URL=postgresql://nixx:changeme@your-public-host:5432/nixx?sslmode=require

# Password for the nixx PostgreSQL role.
# Used by docker-compose and scripts/init-db.sh. Not needed for SQLite (Tier 1).
# NIXX_POSTGRES_PASSWORD=changeme

NIXX_DB_ECHO=false

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# NIXX_ENCRYPTION_KEY=

# ── Hardware monitoring (optional) ────────────────────────────────────────────
NIXX_ENABLE_HARDWARE_MONITORING=false
