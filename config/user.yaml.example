# Nixx User Profile Configuration
# Copy this file to user.yaml and customize for your setup

user:
  name: "Your Name"
  email: "your.email@example.com"
  
  # Short bio/context for Nixx to understand who you are
  bio: |
    ML engineer and data scientist interested in distributed systems,
    self-hosted infrastructure, and practical machine learning applications.
  
  # Current goals and projects Nixx should be aware of
  goals:
    - "Build consulting business focused on ML infrastructure"
    - "Complete ML bootcamp curriculum"
    - "Contribute to open source ML tooling"

personality:
  # Nixx personality configuration
  name: "Nixx"
  style: "technical"  # technical, casual, formal
  humor: "dry"        # dry, playful, none
  formality: "informal"
  
  # System prompt additions (optional)
  custom_instructions: |
    You are Nixx, a technical assistant with dry humor and a cyberpunk aesthetic.
    You're collaborative, not subservient - you help solve problems, not just execute orders.
    Always ask before taking actions. Be direct and efficient in communication.

machines:
  # Define your hardware setup - Nixx will be aware of these
  - name: "ml-box"
    type: "workstation"
    description: "Main ML training machine"
    specs:
      gpu: "NVIDIA P100 16GB"
      cpu: "10+ cores"
      ram: "100GB"
      storage:
        - "NVMe SSD (fast)"
        - "SATA SSD (boot)"
    services:
      - "Ollama"
      - "Nixx backend"
  
  - name: "storage-server"
    type: "server"
    description: "RAID storage server"
    specs:
      storage:
        - "RAID 5 array"
    notes: "Recently recovered from disk failure"
  
  - name: "laptop"
    type: "laptop"
    description: "ThinkPad running Ubuntu"
    specs:
      os: "Ubuntu"
    notes: "Primary development machine"
  
  - name: "htpc"
    type: "server"
    description: "HTPC and Minecraft server"
    specs:
      notes: "Dell workstation with custom paint job"

knowledge:
  # External knowledge sources to integrate
  logseq:
    enabled: true
    path: "~/logseq"
    import_strategy: "selective"  # selective, full, manual
  
  github:
    enabled: true
    username: "yourusername"
    import_strategy: "selective"
    # Specific repos to index (optional, otherwise discovers from profile)
    repos: []

preferences:
  # Interaction preferences
  editor: "zed"  # zed, vscode, neovim
  terminal: "alacritty"
  
  # Memory preferences
  conversation_retention_days: 365
  auto_summarize_old_conversations: true
  
  # Model preferences
  preferred_models:
    coding: "qwen2.5-coder:7b"
    conversation: "qwen2.5:7b"
    summarization: "qwen2.5:7b"
